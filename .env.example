# ==============================================================================
# DELTAOPS ENTERPRISE TRADING PLATFORM - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to .env before running services. NEVER commit real secrets to Git.

# ------------------------------------------------------------------------------
# 1. CORE APPLICATION CONFIGURATION
# ------------------------------------------------------------------------------
APP_NAME=DeltaOps Engine
APP_ENV=development                       # Options: development, staging, production
APP_VERSION=0.1.0-alpha
LOG_LEVEL=INFO                             # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_32_CHAR_SECRET_KEY_MIN

# ------------------------------------------------------------------------------
# 2. DELTA EXCHANGE DEMO / TESTNET API & WEBSOCKET CREDENTIALS
# ------------------------------------------------------------------------------
DELTA_BASE_URL=https://api.demo.delta.exchange
DELTA_WS_URL=wss://socket.demo.delta.exchange
DELTA_API_KEY=your_delta_api_key_here
DELTA_API_SECRET=your_delta_api_secret_here

# ------------------------------------------------------------------------------
# 3. BACKEND SERVER CONFIGURATION
# ------------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
WORKERS=4
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ------------------------------------------------------------------------------
# 4. DATABASE & CACHE (FUTURE PREPARATION)
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://deltaops_user:deltaops_password@localhost:5432/deltaops_db
REDIS_URL=redis://:deltaops_password@localhost:6379/0
