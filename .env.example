# ==============================================================================
# DELTAOPS OBSERVABILITY PLATFORM — ENVIRONMENT TEMPLATE
# Copy to .env — NEVER commit real secrets to Git
# ==============================================================================

# Core Application
APP_NAME=DeltaOps Engine
APP_ENV=development
APP_VERSION=0.1.0-alpha
LOG_LEVEL=INFO
SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_32_CHAR_SECRET_KEY_MIN

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Delta Exchange API
DELTA_BASE_URL=https://api.demo.delta.exchange
DELTA_WS_URL=wss://socket.demo.delta.exchange
DELTA_API_KEY=your_delta_api_key_here
DELTA_API_SECRET=your_delta_api_secret_here

# OpenTelemetry — points to OTel Collector inside Docker network
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Grafana (override defaults in production)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_in_production

# Database & Cache
DATABASE_URL=postgresql+asyncpg://deltaops_user:deltaops_password@localhost:5432/deltaops_db
REDIS_URL=redis://:deltaops_password@localhost:6379/0
