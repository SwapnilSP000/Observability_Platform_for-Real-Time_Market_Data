# ==============================================================================
# DELTAOPS ENTERPRISE GITIGNORE - STRICT SECURITY ENFORCEMENT
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. PYTHON
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
dist/
build/
*.egg

# ------------------------------------------------------------------------------
# 2. VIRTUAL ENVIRONMENTS
# ------------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ------------------------------------------------------------------------------
# 3. ENVIRONMENT & SECRETS (STRICT GUARANTEE - NEVER COMMIT REAL SECRETS)
# ------------------------------------------------------------------------------
.env
.env.*
*.env
frontend/.env
frontend/.env.*
!.env.example
!frontend/.env.example

secrets/
*.pem
*.key
*.crt
*.p12
*.jks
*.keystore
*.id_rsa
*.id_ed25519

# ------------------------------------------------------------------------------
# 4. IDE & EDITORS
# ------------------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.code-workspace
*.obsidian

# ------------------------------------------------------------------------------
# 5. OS ARTIFACTS
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ------------------------------------------------------------------------------
# 6. LOGS & RUNTIME DATA
# ------------------------------------------------------------------------------
*.log
logs/
*.pid
*.seed
*.pid.lock

# ------------------------------------------------------------------------------
# 7. DOCKER & LOCAL DATA
# ------------------------------------------------------------------------------
docker-data/
volumes/
docker-volumes/

# ------------------------------------------------------------------------------
# 8. TESTING & TOX
# ------------------------------------------------------------------------------
.tox/
coverage.xml
nosetests.xml

# ------------------------------------------------------------------------------
# 9. NODE & FRONTEND
# ------------------------------------------------------------------------------
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pnpm-lock.yaml
dist/
frontend/dist/
.next/
out/
.out/

# ------------------------------------------------------------------------------
# 10. TERRAFORM & KUBERNETES
# ------------------------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.backup
crash.log
kubeconfig
*.kubeconfig

# ------------------------------------------------------------------------------
# 11. TEMPORARY FILES
# ------------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
